# AIR POLLUTION APP
library(shiny)
# Data PREP code space in script------------------------------------------------
library(dplyr)
library(ggplot2)
library(readr)
library(DT)
library(plotly)
#Data set from https://ourworldindata.org/air-pollution
url <- 'https://ourworldindata.org/grapher/long-run-air-pollution.csv?v=1&csvType=full&useColumnShortNames=true'
air <- read_csv(url)
air %>% head
#cleaning up data set names
names(air) <- gsub("emissions__pollutant_", "", names(air))
names(air) <- gsub("__sector_all_sectors", "", names(air))
air <- air %>% mutate(total = nox + so2 + co + bc + nh3 + nmvoc)
# Define UI for application that draws a histogram------------------------------
#UI's separate parts with commas
ui <- fluidPage(
titlePanel("The story of air"),
p("Here is a nice little tagline..."),
helpText("more text i guess?"),
tabsetPanel(
tabPanel(h4("Time series"),
fluidRow(column(4, sliderInput(inputId = "year", #naming it
label = "Select years",
min = min(air$year),
max = max(air$year),
value = range(air$year))),
column(4, uiOutput("entity"),
#selectInput(inputId = "entity", #naming it
#            label = "Select countries",
#            multiple = TRUE,
#            choices = unique(air$entity),
#            selected = "United Kingdom"), #giving it a starting point
radioButtons(inputId = "rank",
label = "Rank countries ...",
choices = c("Alphabetically", "By total emissions"),
selected = "Alphabetically",
inline = TRUE)),
column(4, radioButtons(inputId = "yvar", #naming it
label = "Select variable",
choices = names(air)[-1:-3],
selected = "total", #starting point
inline = TRUE))),
br(),
br(),
fluidRow(column(1),
column(10, plotOutput("airplot")), #naming it
column(1))
),
tabPanel(h4("Data viewer"),
fluidRow(column(12, DTOutput("dt1"))) #naming it
)
)
)
# Define SERVER logic required to draw a histogram------------------------------
#servers separate with with ({}) = squiggle-bob hugs
server <- function(input, output) {
#to make REACTIVE VALUES - to make a change through-out the entire app
rv <- reactiveValues()
rv$air <- air
observe({
if(! is.null(input$entity)){
rv$air <- air %>% filter(entity %in% input$entity)
}else{
rv$air <- air
}
})
output$entity <- renderUI({
#create default: alphabet
countries <- air %>% pull(entity) %>% unique %>% sort
#"if input$rank is NOT "alphabetical", rank them by emissions"
if(input$rank == "By total emissions"){
countries <- air %>%
group_by(entity) %>%
summarize(total = sum(total)) %>%
arrange(desc(total)) %>%
pull(entity)
}
#then build up selectInput
selectInput(inputId = "entity",
label = "Select countries",
multiple = TRUE,
choices = countries,
selected = "United Kingdon")
})
output$airplot <- renderPlot({ #referenced
print(input$entity) #referenced
if(input$entity %>% is.null){
#this is where ALL countries are shown
ggplot(rv$air,
aes_string(x = "year",
y = input$yvar,
group = "entity"))+
geom_path()+
xlim(input$year)
}else{
#this is where only selected countries are shown
ggplot(rv$air,
#air %>% filter(entity %in% input$entity), #referenced in line 36 #using the rv instead
#aes(x = year, y = total, group = entity)+ #the original before we got fancy
aes_string(x = "year",
y = input$yvar, #change from "total", and not it will choose whichever you are selecting/printing (line 64)
color = "entity"))+
geom_path()+
xlim(input$year) #referenced in line 31
}
})
output$dt1 <- renderDT({ rv$air }) #referenced
}
# Run the APPLICATION-----------------------------------------------------------
shinyApp(ui = ui, server = server)
shiny::runApp('DataStory/repos/Data-Story-4/docs')
